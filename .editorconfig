root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
indent_style = space
indent_size = 4
max_line_length = 100
ktlint_code_style = ktlint_official
# Octarine uses SCREAMING_CASE for singletons (INSTANCE) and registry entries
# (e.g. OCTIRON_ORE, THAUM, BALROG) throughout — an established, deliberate
# convention, so the property-naming rule is intentionally disabled.
ktlint_standard_property-naming = disabled

[*.json]
indent_style = space
indent_size = 4
max_line_length = 100
